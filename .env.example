# ============================================================
# NEGO — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# === DOMAINE ===
NEGO_DOMAIN=hego.joranbatty.fr
NEGO_EMAIL=contact@joranbatty.fr

# === ELASTICSEARCH ===
ELASTIC_VERSION=8.17.0
ELASTIC_PASSWORD=changeme_elastic_password
ELASTIC_CLUSTER_NAME=nego
ELASTIC_HEAP_SIZE=2g

# === OPENCTI ===
OPENCTI_VERSION=latest
OPENCTI_ADMIN_EMAIL=admin@nego.local
OPENCTI_ADMIN_PASSWORD=changeme_opencti_password
OPENCTI_ADMIN_TOKEN=changeme-0000-0000-0000-000000000000
OPENCTI_HEALTHCHECK_KEY=changeme-0000-0000-0000-000000000001

# === RABBITMQ ===
RABBITMQ_DEFAULT_USER=opencti
RABBITMQ_DEFAULT_PASS=changeme_rabbitmq_password

# === MINIO ===
MINIO_ROOT_USER=opencti
MINIO_ROOT_PASSWORD=changeme_minio_password

# === N8N ===
N8N_ENCRYPTION_KEY=changeme_n8n_encryption_key!!

# === AUTHELIA ===
AUTHELIA_JWT_SECRET=changeme_authelia_jwt_secret_key
AUTHELIA_SESSION_SECRET=changeme_authelia_session_secret
AUTHELIA_STORAGE_ENCRYPTION_KEY=changeme_authelia_storage_key

# === ACLED ===
ACLED_API_KEY=your_acled_api_key_here
ACLED_EMAIL=your_acled_email_here

# === ALERTING ===
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook
ALERT_EMAIL_SMTP_HOST=smtp.example.com
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_FROM=hego@joranbatty.fr
ALERT_EMAIL_TO=joran@joranbatty.fr
ALERT_EMAIL_PASSWORD=changeme_smtp_password

# === OPENCTI CONNECTORS ===
MITRE_CONNECTOR_ID=changeme-0000-0000-0000-000000000010
ALIENVAULT_API_KEY=your_otx_api_key_here
ALIENVAULT_CONNECTOR_ID=changeme-0000-0000-0000-000000000011
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
ABUSEIPDB_CONNECTOR_ID=changeme-0000-0000-0000-000000000012
CISA_KEV_CONNECTOR_ID=changeme-0000-0000-0000-000000000013
CVE_CONNECTOR_ID=changeme-0000-0000-0000-000000000014
OPENCTI_DATASETS_CONNECTOR_ID=changeme-0000-0000-0000-000000000015
