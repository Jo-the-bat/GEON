{
    "schema_version": 1,
    "name": "HEGO - Defense & Cybersecurity RSS Feeds",
    "description": "Aggregates articles from defense publications and cybersecurity organizations (ANSSI, CERT-FR, CISA, ENISA, Defense One).",
    "guid": "hego-rss-defense-v1",
    "exported_at": "2025-06-15T00:00:00Z",
    "agents": [
        {
            "type": "Agents::RssAgent",
            "name": "RSS - ANSSI Alerts",
            "disabled": false,
            "options": {
                "url": "https://www.cert.ssi.gouv.fr/feed/",
                "expected_update_period_in_days": 3,
                "clean": true,
                "headers": {}
            },
            "schedule": "every_1h",
            "keep_events_for": 604800,
            "propagate_immediately": true
        },
        {
            "type": "Agents::RssAgent",
            "name": "RSS - CERT-FR Advisories",
            "disabled": false,
            "options": {
                "url": "https://www.cert.ssi.gouv.fr/avis/feed/",
                "expected_update_period_in_days": 3,
                "clean": true,
                "headers": {}
            },
            "schedule": "every_1h",
            "keep_events_for": 604800,
            "propagate_immediately": true
        },
        {
            "type": "Agents::RssAgent",
            "name": "RSS - CISA",
            "disabled": false,
            "options": {
                "url": "https://www.cisa.gov/news.xml",
                "expected_update_period_in_days": 2,
                "clean": true,
                "headers": {}
            },
            "schedule": "every_1h",
            "keep_events_for": 604800,
            "propagate_immediately": true
        },
        {
            "type": "Agents::RssAgent",
            "name": "RSS - ENISA",
            "disabled": false,
            "options": {
                "url": "https://www.enisa.europa.eu/rss.xml",
                "expected_update_period_in_days": 5,
                "clean": true,
                "headers": {}
            },
            "schedule": "every_2h",
            "keep_events_for": 604800,
            "propagate_immediately": true
        },
        {
            "type": "Agents::RssAgent",
            "name": "RSS - Defense One",
            "disabled": false,
            "options": {
                "url": "https://www.defenseone.com/rss/",
                "expected_update_period_in_days": 1,
                "clean": true,
                "headers": {}
            },
            "schedule": "every_1h",
            "keep_events_for": 604800,
            "propagate_immediately": true
        },
        {
            "type": "Agents::TriggerAgent",
            "name": "Filter - Defense & Cyber Keywords",
            "disabled": false,
            "options": {
                "rules": [
                    {
                        "type": "regex",
                        "value": "(?i)(CVE|vulnerability|exploit|malware|ransomware|APT|threat|phishing|C2|command.and.control|zero.day|patch|advisory|alert|incident|breach|campaign|intrusion|military|defense|defence|weapon|missile|drone|nuclear|deployment|exercise|maritime|aviation|space|satellite|intelligence)",
                        "path": "title"
                    }
                ],
                "must_match": 1
            },
            "keep_events_for": 604800,
            "propagate_immediately": true,
            "sources": [
                "RSS - ANSSI Alerts", "RSS - CERT-FR Advisories",
                "RSS - CISA", "RSS - ENISA", "RSS - Defense One"
            ]
        },
        {
            "type": "Agents::WebhookAgent",
            "name": "Push to Elasticsearch",
            "disabled": false,
            "options": {
                "url": "http://elasticsearch:9200/hego-articles-{{ 'now' | date: '%Y.%m' }}/_doc",
                "method": "post",
                "content_type": "json",
                "headers": {
                    "Authorization": "Basic {{ 'elastic:${ELASTIC_PASSWORD}' | base64 }}"
                },
                "payload": {
                    "title": "{{ title }}",
                    "url": "{{ url }}",
                    "source": "{{ agent_name }}",
                    "published_date": "{{ date_published }}",
                    "description": "{{ description | strip_html | truncate: 500 }}",
                    "category": "defense_cyber",
                    "ingested_at": "{{ 'now' | date: '%Y-%m-%dT%H:%M:%SZ' }}"
                }
            },
            "keep_events_for": 86400,
            "propagate_immediately": false,
            "sources": ["Filter - Defense & Cyber Keywords"]
        }
    ],
    "links": [
        {"source": 0, "receiver": 5},
        {"source": 1, "receiver": 5},
        {"source": 2, "receiver": 5},
        {"source": 3, "receiver": 5},
        {"source": 4, "receiver": 5},
        {"source": 5, "receiver": 6}
    ]
}
