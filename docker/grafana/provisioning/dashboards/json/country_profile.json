{
  "uid": "geon-country-profile",
  "title": "GEON \u2014 Country Profile",
  "tags": ["geon", "country"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "5m",
  "schemaVersion": 39,
  "time": {
    "from": "now-90d",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "country",
        "label": "Country",
        "type": "query",
        "datasource": { "uid": "elasticsearch" },
        "query": "{\"find\": \"terms\", \"field\": \"source_country\", \"query\": \"_index:geon-gdelt-*\"}",
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "current": {},
        "options": []
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Events Timeline \u2014 $country",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [
        {
          "refId": "A",
          "query": "_index:geon-gdelt-* AND source_country:\"$country\"",
          "alias": "GDELT Events",
          "metrics": [
            { "id": "1", "type": "count" }
          ],
          "bucketAggs": [
            {
              "id": "2",
              "type": "date_histogram",
              "field": "date",
              "settings": { "interval": "1d", "min_doc_count": "0" }
            }
          ],
          "timeField": "date"
        },
        {
          "refId": "B",
          "query": "_index:geon-acled-* AND country:\"$country\"",
          "alias": "ACLED Events",
          "metrics": [
            { "id": "1", "type": "count" }
          ],
          "bucketAggs": [
            {
              "id": "2",
              "type": "date_histogram",
              "field": "date",
              "settings": { "interval": "1d", "min_doc_count": "0" }
            }
          ],
          "timeField": "date"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "pointSize": 5,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 2,
      "title": "APT Groups \u2014 $country",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 10 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [
        {
          "refId": "A",
          "query": "_index:geon-cti-* AND country:\"$country\"",
          "alias": "",
          "metrics": [
            {
              "id": "1",
              "type": "raw_data",
              "settings": { "size": "50" }
            }
          ],
          "bucketAggs": [],
          "timeField": "date"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "date", "desc": true }]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "includeByName": {
              "name": true,
              "aliases": true,
              "country": true,
              "techniques": true,
              "last_seen": true
            },
            "indexByName": {
              "name": 0,
              "aliases": 1,
              "country": 2,
              "techniques": 3,
              "last_seen": 4
            }
          }
        }
      ]
    },
    {
      "id": 3,
      "title": "Active Sanctions \u2014 $country",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 10 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [
        {
          "refId": "A",
          "query": "_index:geon-sanctions AND country:\"$country\"",
          "alias": "",
          "metrics": [
            {
              "id": "1",
              "type": "raw_data",
              "settings": { "size": "50" }
            }
          ],
          "bucketAggs": [],
          "timeField": "date"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "date", "desc": true }]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "includeByName": {
              "entity_name": true,
              "sanction_source": true,
              "country": true,
              "reason": true,
              "date": true
            },
            "indexByName": {
              "entity_name": 0,
              "sanction_source": 1,
              "country": 2,
              "reason": 3,
              "date": 4
            }
          }
        }
      ]
    },
    {
      "id": 4,
      "title": "Risk Score \u2014 $country",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 20 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [
        {
          "refId": "A",
          "query": "_index:geon-gdelt-* AND source_country:\"$country\"",
          "alias": "GDELT Events",
          "metrics": [
            { "id": "1", "type": "count" }
          ],
          "bucketAggs": [
            {
              "id": "2",
              "type": "date_histogram",
              "field": "date",
              "settings": { "interval": "1d", "min_doc_count": "0" }
            }
          ],
          "timeField": "date"
        },
        {
          "refId": "B",
          "query": "_index:geon-correlations AND countries_involved:\"$country\"",
          "alias": "Correlations",
          "metrics": [
            { "id": "1", "type": "count" }
          ],
          "bucketAggs": [
            {
              "id": "2",
              "type": "date_histogram",
              "field": "timestamp",
              "settings": { "interval": "1d", "min_doc_count": "0" }
            }
          ],
          "timeField": "date"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "orange", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "title": "Recent Articles \u2014 $country",
      "type": "table",
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 20 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [
        {
          "refId": "A",
          "query": "_index:geon-articles-* AND country:\"$country\"",
          "alias": "",
          "metrics": [
            {
              "id": "1",
              "type": "raw_data",
              "settings": { "size": "20" }
            }
          ],
          "bucketAggs": [],
          "timeField": "date"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "date", "desc": true }]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "includeByName": {
              "title": true,
              "source": true,
              "date": true,
              "country": true,
              "url": true
            },
            "indexByName": {
              "title": 0,
              "source": 1,
              "date": 2,
              "country": 3,
              "url": 4
            }
          }
        }
      ]
    },
    {
      "id": 8,
      "title": "Risk Score \u2014 $country",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 30 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [{
        "refId": "A",
        "query": "_index:geon-risk-scores AND country:\"$country\"",
        "metrics": [{ "id": "1", "type": "raw_data", "settings": { "size": "1" } }],
        "bucketAggs": [],
        "timeField": "date"
      }],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 25 },
            { "color": "orange", "value": 50 },
            { "color": "red", "value": 75 }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/.*risk_score.*/", "values": false },
        "showThresholdLabels": true
      },
      "transformations": [{
        "id": "filterFieldsByName",
        "options": { "include": { "names": ["risk_score"] } }
      }]
    },
    {
      "id": 9,
      "title": "Polymarket Cases \u2014 $country",
      "type": "table",
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 30 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [{
        "refId": "A",
        "query": "_index:geon-polymarket-cases AND countries_involved:\"$country\"",
        "metrics": [{ "id": "1", "type": "raw_data", "settings": { "size": "10" } }],
        "bucketAggs": [],
        "timeField": "date"
      }],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true },
      "transformations": [{
        "id": "organize",
        "options": {
          "includeByName": { "question": true, "outcome_yes_price": true, "volume": true, "trend": true },
          "indexByName": { "question": 0, "outcome_yes_price": 1, "volume": 2, "trend": 3 }
        }
      }]
    }
    ,{
      "id": 10,
      "title": "Internet Outages History \u2014 $country",
      "type": "table",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 36 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [{
        "refId": "A",
        "query": "_index:geon-outages AND country:\"$country\"",
        "metrics": [{ "id": "1", "type": "raw_data", "settings": { "size": "20" } }],
        "bucketAggs": [],
        "timeField": "date"
      }],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "start_time", "desc": true }] },
      "transformations": [{
        "id": "organize",
        "options": {
          "includeByName": { "start_time": true, "type": true, "severity": true, "duration_hours": true, "status": true },
          "indexByName": { "start_time": 0, "type": 1, "severity": 2, "duration_hours": 3, "status": 4 }
        }
      }]
    },
    {
      "id": 11,
      "title": "Arms Imports/Exports \u2014 $country",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [
        {
          "refId": "A",
          "query": "_index:geon-arms-transfers AND recipient_country:\"$country\"",
          "alias": "Imports (TIV)",
          "metrics": [{ "id": "1", "type": "sum", "field": "tiv_value" }],
          "bucketAggs": [{ "id": "2", "type": "terms", "field": "supplier_country", "settings": { "size": "10", "order": "desc", "orderBy": "1" } }],
          "timeField": "date"
        },
        {
          "refId": "B",
          "query": "_index:geon-arms-transfers AND supplier_country:\"$country\"",
          "alias": "Exports (TIV)",
          "metrics": [{ "id": "1", "type": "sum", "field": "tiv_value" }],
          "bucketAggs": [{ "id": "2", "type": "terms", "field": "recipient_country", "settings": { "size": "10", "order": "desc", "orderBy": "1" } }],
          "timeField": "date"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "orientation": "horizontal", "barWidth": 0.8, "showValue": "auto", "stacking": "none" }
    },
    {
      "id": 12,
      "title": "Military Spending Trend \u2014 $country",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 44 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [{
        "refId": "A",
        "query": "_index:geon-military-spending AND country:\"$country\"",
        "alias": "Spending (USD M)",
        "metrics": [{ "id": "1", "type": "max", "field": "spending_usd_millions" }],
        "bucketAggs": [{ "id": "2", "type": "date_histogram", "field": "date", "settings": { "interval": "1y", "min_doc_count": "0" } }],
        "timeField": "date"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 60, "lineWidth": 1, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 13,
      "title": "Military Spending % GDP \u2014 $country",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 44 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [{
        "refId": "A",
        "query": "_index:geon-military-spending AND country:\"$country\"",
        "metrics": [{ "id": "1", "type": "raw_data", "settings": { "size": "1" } }],
        "bucketAggs": [],
        "timeField": "date"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "yellow", "value": 2 },
            { "color": "orange", "value": 3 }, { "color": "red", "value": 5 }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/.*spending_pct_gdp.*/", "values": false },
        "colorMode": "background", "graphMode": "none", "textMode": "auto"
      },
      "transformations": [{ "id": "filterFieldsByName", "options": { "include": { "names": ["spending_pct_gdp"] } } }]
    }
  ],
  "version": 4
}
