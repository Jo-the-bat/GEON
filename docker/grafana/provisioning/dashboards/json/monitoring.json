{
  "uid": "geon-monitoring",
  "title": "GEON \u2014 Platform Monitoring",
  "tags": ["geon", "monitoring", "ops"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Service Health (Prometheus Targets)",
      "description": "Services with native /metrics endpoints scraped by Prometheus. Other services (Nginx, Redis, MinIO, Authelia, Elasticsearch) are monitored via Docker healthchecks.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 0 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "up",
          "legendFormat": "{{job}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "orientation": "horizontal"
      }
    },
    {
      "id": 2,
      "title": "Last Ingestion Timestamps",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [
        {
          "refId": "A",
          "query": "_index:geon-gdelt-*",
          "alias": "GDELT",
          "metrics": [
            { "id": "1", "type": "max", "field": "ingested_at" }
          ],
          "bucketAggs": [],
          "timeField": "date"
        },
        {
          "refId": "B",
          "query": "_index:geon-cti-*",
          "alias": "OpenCTI Export",
          "metrics": [
            { "id": "1", "type": "max", "field": "ingested_at" }
          ],
          "bucketAggs": [],
          "timeField": "ingested_at"
        },
        {
          "refId": "C",
          "query": "_index:geon-sanctions",
          "alias": "Sanctions",
          "metrics": [
            { "id": "1", "type": "max", "field": "ingested_at" }
          ],
          "bucketAggs": [],
          "timeField": "ingested_at"
        },
        {
          "refId": "D",
          "query": "_index:geon-correlations",
          "alias": "Correlations",
          "metrics": [
            { "id": "1", "type": "max", "field": "timestamp" }
          ],
          "bucketAggs": [],
          "timeField": "timestamp"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 3,
      "title": "Prometheus Scrape Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "scrape_duration_seconds",
          "legendFormat": "{{job}}",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 4,
      "title": "Total Documents Across All Indices",
      "type": "stat",
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 13 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [
        {
          "refId": "A",
          "query": "_index:geon-gdelt-*",
          "alias": "GDELT",
          "metrics": [
            { "id": "1", "type": "count" }
          ],
          "bucketAggs": [
            {
              "id": "2",
              "type": "date_histogram",
              "field": "date",
              "settings": { "interval": "1d", "min_doc_count": "0" }
            }
          ],
          "timeField": "date"
        },
        {
          "refId": "B",
          "query": "_index:geon-cti-*",
          "alias": "CTI",
          "metrics": [
            { "id": "1", "type": "count" }
          ],
          "bucketAggs": [
            {
              "id": "2",
              "type": "date_histogram",
              "field": "ingested_at",
              "settings": { "interval": "1d", "min_doc_count": "0" }
            }
          ],
          "timeField": "ingested_at"
        },
        {
          "refId": "C",
          "query": "_index:geon-sanctions",
          "alias": "Sanctions",
          "metrics": [
            { "id": "1", "type": "count" }
          ],
          "bucketAggs": [
            {
              "id": "2",
              "type": "date_histogram",
              "field": "ingested_at",
              "settings": { "interval": "1d", "min_doc_count": "0" }
            }
          ],
          "timeField": "ingested_at"
        },
        {
          "refId": "D",
          "query": "_index:geon-correlations",
          "alias": "Correlations",
          "metrics": [
            { "id": "1", "type": "count" }
          ],
          "bucketAggs": [
            {
              "id": "2",
              "type": "date_histogram",
              "field": "timestamp",
              "settings": { "interval": "1d", "min_doc_count": "0" }
            }
          ],
          "timeField": "timestamp"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto",
        "orientation": "horizontal"
      }
    }
  ],
  "version": 3
}
