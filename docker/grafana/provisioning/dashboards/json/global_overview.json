{
  "uid": "geon-global-overview",
  "title": "GEON \u2014 Global Overview",
  "tags": ["geon", "overview"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "5m",
  "schemaVersion": 39,
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "GDELT Events \u2014 World Map",
      "type": "geomap",
      "gridPos": { "h": 12, "w": 16, "x": 0, "y": 0 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [
        {
          "refId": "A",
          "query": "geo_location:*",
          "alias": "Events",
          "metrics": [
            {
              "id": "1",
              "type": "raw_data",
              "settings": { "size": "500" }
            }
          ],
          "bucketAggs": [],
          "timeField": "date"
        }
      ],
      "options": {
        "view": {
          "id": "coords",
          "lat": 20,
          "lon": 0,
          "zoom": 2
        },
        "basemap": {
          "type": "default",
          "name": "World"
        },
        "layers": [
          {
            "type": "markers",
            "name": "GDELT Events",
            "location": {
              "mode": "coords",
              "latitude": "geo_lat",
              "longitude": "geo_lon"
            },
            "config": {
              "showLegend": false,
              "style": {
                "size": { "fixed": 4 },
                "color": { "fixed": "semi-dark-red" },
                "opacity": 0.6,
                "symbol": { "fixed": "circle" }
              }
            }
          }
        ]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "GDELT Event Count Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 12 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [
        {
          "refId": "A",
          "query": "_index:geon-gdelt-*",
          "alias": "GDELT Events",
          "metrics": [
            { "id": "1", "type": "count" }
          ],
          "bucketAggs": [
            {
              "id": "2",
              "type": "date_histogram",
              "field": "date",
              "settings": { "interval": "1d", "min_doc_count": "0" }
            }
          ],
          "timeField": "date"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "lineInterpolation": "smooth",
            "fillOpacity": 60,
            "pointSize": 5,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 3,
      "title": "Top 10 Countries by Event Count",
      "type": "bargauge",
      "gridPos": { "h": 12, "w": 8, "x": 16, "y": 0 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [
        {
          "refId": "A",
          "query": "_index:geon-gdelt-*",
          "alias": "",
          "metrics": [
            { "id": "1", "type": "count" }
          ],
          "bucketAggs": [
            {
              "id": "2",
              "type": "terms",
              "field": "source_country",
              "settings": {
                "size": "10",
                "order": "desc",
                "orderBy": "_count",
                "min_doc_count": "1"
              }
            }
          ],
          "timeField": "date"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true
      }
    },
    {
      "id": 4,
      "title": "Total Events Ingested",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 12 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [
        {
          "refId": "A",
          "query": "_index:geon-gdelt-*",
          "alias": "Events",
          "metrics": [
            { "id": "1", "type": "count" }
          ],
          "bucketAggs": [
            {
              "id": "2",
              "type": "date_histogram",
              "field": "date",
              "settings": { "interval": "1d", "min_doc_count": "0" }
            }
          ],
          "timeField": "date"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 100 },
              { "color": "yellow", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "title": "Severity Breakdown",
      "type": "piechart",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 12 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [
        {
          "refId": "A",
          "query": "_index:geon-gdelt-*",
          "alias": "",
          "metrics": [
            { "id": "1", "type": "count" }
          ],
          "bucketAggs": [
            {
              "id": "2",
              "type": "terms",
              "field": "severity",
              "settings": {
                "size": "5",
                "order": "desc",
                "orderBy": "_count"
              }
            }
          ],
          "timeField": "date"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "critical" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "high" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "medium" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "low" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "pieType": "donut",
        "legend": { "displayMode": "list", "placement": "right" }
      }
    },
    {
      "id": 6,
      "title": "Latest GDELT Events",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [
        {
          "refId": "A",
          "query": "_index:geon-gdelt-*",
          "alias": "",
          "metrics": [
            {
              "id": "1",
              "type": "raw_data",
              "settings": { "size": "20" }
            }
          ],
          "bucketAggs": [],
          "timeField": "date"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "source_url" },
            "properties": [
              { "id": "links", "value": [{ "title": "Open", "url": "${__value.text}", "targetBlank": true }] }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "date", "desc": true }]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "includeByName": {
              "date": true,
              "source_country": true,
              "severity": true,
              "cameo_description": true,
              "source_url": true
            },
            "indexByName": {
              "date": 0,
              "source_country": 1,
              "severity": 2,
              "cameo_description": 3,
              "source_url": 4
            }
          }
        }
      ]
    },
    {
      "id": 7,
      "title": "Active Prediction Markets (Top 5 by Volume)",
      "type": "table",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 28 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [{
        "refId": "A",
        "query": "_index:geon-polymarket-cases AND status:active",
        "metrics": [{ "id": "1", "type": "raw_data", "settings": { "size": "5" } }],
        "bucketAggs": [],
        "timeField": "date"
      }],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "volume", "desc": true }]
      },
      "transformations": [{
        "id": "organize",
        "options": {
          "includeByName": { "question": true, "outcome_yes_price": true, "volume": true, "trend": true, "countries_involved": true },
          "indexByName": { "question": 0, "outcome_yes_price": 1, "volume": 2, "trend": 3, "countries_involved": 4 }
        }
      }]
    }
  ],
  "version": 3
}
