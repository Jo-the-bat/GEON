{
  "uid": "geon-prediction-markets",
  "title": "GEON \u2014 Prediction Markets",
  "tags": ["geon", "polymarket", "predictions"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "5m",
  "schemaVersion": 39,
  "time": { "from": "now-30d", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Active Prediction Markets",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [{
        "refId": "A",
        "query": "_index:geon-polymarket-cases AND status:active",
        "metrics": [{ "id": "1", "type": "count" }],
        "bucketAggs": [{ "id": "2", "type": "date_histogram", "field": "date", "settings": { "interval": "1d", "min_doc_count": "0" } }],
        "timeField": "date"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "colorMode": "background", "graphMode": "none", "textMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "Significant Price Movements (>10%) This Week",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [{
        "refId": "A",
        "query": "_index:geon-correlations AND rule_name:prediction_market_shift",
        "metrics": [{ "id": "1", "type": "count" }],
        "bucketAggs": [{ "id": "2", "type": "date_histogram", "field": "date", "settings": { "interval": "1w", "min_doc_count": "0" } }],
        "timeField": "date"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 3 }, { "color": "red", "value": 10 }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "colorMode": "background", "graphMode": "none", "textMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "Total Volume (USD)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [{
        "refId": "A",
        "query": "_index:geon-polymarket-cases AND status:active",
        "metrics": [{ "id": "1", "type": "sum", "field": "volume" }],
        "bucketAggs": [{ "id": "2", "type": "date_histogram", "field": "date", "settings": { "interval": "1d", "min_doc_count": "0" } }],
        "timeField": "date"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "none", "textMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "Related GEON Events (sum across all cases)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [{
        "refId": "A",
        "query": "_index:geon-polymarket-cases AND status:active",
        "metrics": [{ "id": "1", "type": "sum", "field": "related_gdelt_events" }],
        "bucketAggs": [{ "id": "2", "type": "date_histogram", "field": "date", "settings": { "interval": "1d", "min_doc_count": "0" } }],
        "timeField": "date"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "none", "textMode": "auto"
      }
    },
    {
      "id": 5,
      "title": "Active Geopolitical Markets",
      "type": "table",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 4 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [{
        "refId": "A",
        "query": "_index:geon-polymarket-cases AND status:active",
        "metrics": [{ "id": "1", "type": "raw_data", "settings": { "size": "50" } }],
        "bucketAggs": [],
        "timeField": "date"
      }],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "source_url" }, "properties": [{ "id": "links", "value": [{ "title": "Open", "url": "${__value.text}", "targetBlank": true }] }] }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "volume", "desc": true }]
      },
      "transformations": [{
        "id": "organize",
        "options": {
          "includeByName": {
            "question": true,
            "outcome_yes_price": true,
            "volume": true,
            "trend": true,
            "countries_involved": true,
            "related_gdelt_events": true,
            "related_correlations": true,
            "source_url": true
          },
          "indexByName": {
            "question": 0,
            "outcome_yes_price": 1,
            "consensus.consensus_score": 2,
            "consensus.divergence": 3,
            "volume": 4,
            "trend": 5,
            "countries_involved": 6,
            "related_gdelt_events": 7,
            "related_correlations": 8,
            "source_url": 9
          },
          "includeByName": {
            "question": true,
            "outcome_yes_price": true,
            "consensus.consensus_score": true,
            "consensus.divergence": true,
            "volume": true,
            "trend": true,
            "countries_involved": true,
            "related_gdelt_events": true,
            "related_correlations": true,
            "source_url": true
          }
        }
      }]
    },
    {
      "id": 6,
      "title": "Recent Price Shift Alerts",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [{
        "refId": "A",
        "query": "_index:geon-correlations AND rule_name:prediction_market_shift",
        "metrics": [{ "id": "1", "type": "raw_data", "settings": { "size": "20" } }],
        "bucketAggs": [],
        "timeField": "date"
      }],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "date", "desc": true }]
      },
      "transformations": [{
        "id": "organize",
        "options": {
          "includeByName": {
            "date": true,
            "severity": true,
            "description": true,
            "countries_involved": true
          },
          "indexByName": { "date": 0, "severity": 1, "description": 2, "countries_involved": 3 }
        }
      }]
    }
    ,{
      "id": 7,
      "title": "Platform Divergences (>10%)",
      "type": "table",
      "gridPos": { "h": 8, "w": 18, "x": 0, "y": 24 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [{
        "refId": "A",
        "query": "_index:geon-polymarket-cases AND consensus.divergence:>0.10",
        "metrics": [{ "id": "1", "type": "raw_data", "settings": { "size": "20" } }],
        "bucketAggs": [],
        "timeField": "date"
      }],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "consensus.divergence", "desc": true }]
      },
      "transformations": [{
        "id": "organize",
        "options": {
          "includeByName": {
            "question": true,
            "consensus.polymarket_yes": true,
            "consensus.metaculus_median": true,
            "consensus.manifold_yes": true,
            "consensus.divergence": true,
            "consensus.platforms_count": true
          },
          "indexByName": {
            "question": 0,
            "consensus.polymarket_yes": 1,
            "consensus.metaculus_median": 2,
            "consensus.manifold_yes": 3,
            "consensus.divergence": 4,
            "consensus.platforms_count": 5
          }
        }
      }]
    },
    {
      "id": 8,
      "title": "Avg Consensus Divergence",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 24 },
      "datasource": { "uid": "elasticsearch" },
      "targets": [{
        "refId": "A",
        "query": "_index:geon-polymarket-cases AND consensus.divergence:>0",
        "metrics": [{ "id": "1", "type": "avg", "field": "consensus.divergence" }],
        "bucketAggs": [{ "id": "2", "type": "date_histogram", "field": "date", "settings": { "interval": "1d", "min_doc_count": "0" } }],
        "timeField": "date"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.10 },
            { "color": "orange", "value": 0.15 },
            { "color": "red", "value": 0.20 }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background", "graphMode": "area", "textMode": "auto"
      }
    }
  ],
  "version": 2
}
