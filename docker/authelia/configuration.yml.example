# =============================================================================
# GEON — Authelia Configuration
# Centralized authentication with MFA (TOTP)
# =============================================================================

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
server:
  address: 'tcp://0.0.0.0:9091/auth'
  buffers:
    read: 4096
    write: 4096
  timeouts:
    read: '6s'
    write: '6s'
    idle: '30s'

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
log:
  level: 'info'
  format: 'text'

# ---------------------------------------------------------------------------
# Theme
# ---------------------------------------------------------------------------
theme: 'dark'

# ---------------------------------------------------------------------------
# JWT Secret (injected via environment variable AUTHELIA_JWT_SECRET)
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# TOTP — Time-based One-Time Password
# ---------------------------------------------------------------------------
totp:
  disable: false
  issuer: 'GEON'
  algorithm: 'sha1'
  digits: 6
  period: 30
  skew: 1

# ---------------------------------------------------------------------------
# WebAuthn (disabled, TOTP only)
# ---------------------------------------------------------------------------
webauthn:
  disable: true

# ---------------------------------------------------------------------------
# Authentication Backend — File Provider
# ---------------------------------------------------------------------------
authentication_backend:
  file:
    path: '/config/users_database.yml'
    watch: true
    password:
      algorithm: 'argon2id'
      iterations: 3
      memory: 65536
      parallelism: 4
      key_length: 32
      salt_length: 16

# ---------------------------------------------------------------------------
# Access Control
# ---------------------------------------------------------------------------
access_control:
  default_policy: 'deny'

  rules:
    # Authelia portal itself must be accessible
    - domain: 'geon.joranbatty.fr'
      policy: 'bypass'
      resources:
        - '^/auth([/?].*)?$'

    # Landing page is public
    - domain: 'geon.joranbatty.fr'
      policy: 'bypass'
      resources:
        - '^/$'
        - '^/index\.html$'
        - '^/style\.css$'
        - '^/assets(/.*)?$'
        - '^/favicon\.ico$'

    # ACME challenge for Let's Encrypt
    - domain: 'geon.joranbatty.fr'
      policy: 'bypass'
      resources:
        - '^/\.well-known(/.*)?$'

    # OpenCTI — requires two-factor authentication
    - domain: 'geon.joranbatty.fr'
      policy: 'two_factor'
      resources:
        - '^/opencti([/?].*)?$'

    # n8n — requires two-factor authentication
    - domain: 'geon.joranbatty.fr'
      policy: 'two_factor'
      resources:
        - '^/n8n([/?].*)?$'

    # Grafana — requires two-factor authentication
    - domain: 'geon.joranbatty.fr'
      policy: 'two_factor'
      resources:
        - '^/grafana([/?].*)?$'

# ---------------------------------------------------------------------------
# Session
# ---------------------------------------------------------------------------
session:
  name: 'geon_session'
  same_site: 'lax'
  expiration: '1h'
  inactivity: '5m'
  remember_me: '1M'
  cookies:
    - domain: 'geon.joranbatty.fr'
      authelia_url: 'https://geon.joranbatty.fr/auth'
      default_redirection_url: 'https://geon.joranbatty.fr'

# ---------------------------------------------------------------------------
# Regulation — Brute Force Protection
# ---------------------------------------------------------------------------
regulation:
  max_retries: 3
  find_time: '2m'
  ban_time: '5m'

# ---------------------------------------------------------------------------
# Storage — Local SQLite3
# ---------------------------------------------------------------------------
storage:
  local:
    path: '/config/data/db.sqlite3'

# ---------------------------------------------------------------------------
# Notifier — Filesystem (dev mode)
# For production, replace with SMTP:
#   notifier:
#     smtp:
#       address: 'smtp://smtp.example.com:587'
#       username: 'geon@joranbatty.fr'
#       password: 'smtp_password'
#       sender: 'GEON Auth <geon@joranbatty.fr>'
#       subject: '[GEON] {title}'
# ---------------------------------------------------------------------------
notifier:
  filesystem:
    filename: '/config/data/notification.txt'
