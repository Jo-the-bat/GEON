# =============================================================================
# GEON — Authelia Users Database
# =============================================================================
#
# To generate a password hash, run:
#   docker run --rm authelia/authelia authelia crypto hash generate argon2 --password 'YOUR_PASSWORD'
#
# Then replace the hash below with the output.
# =============================================================================

users:
  admin:
    disabled: false
    displayname: 'GEON Administrator'
    password: '<GENERATE: docker run --rm authelia/authelia authelia crypto hash generate argon2 --password YOUR_PASSWORD>'
    email: 'admin@geon.local'
    groups:
      - 'admins'
      - 'geon-users'
